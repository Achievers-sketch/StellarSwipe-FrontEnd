# Web Vitals Sampling Rate
# Controls what percentage of page loads report Core Web Vitals to analytics
# Value should be between 0.0 (0%) and 1.0 (100%)
# Default: 0.1 (10% of page loads)
# Set to 1.0 to report all page loads (may increase analytics costs)
# Set to 0.0 to disable Web Vitals reporting entirely
NEXT_PUBLIC_WEB_VITALS_SAMPLING_RATE=0.1

# Sentry Error Tracking
# DSN for Sentry error reporting - get this from your Sentry project settings
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Stellar Network
# The Stellar network this app connects to. Must match the network your wallet
# is configured for. Values: TESTNET | PUBLIC (mainnet)
# Default: TESTNET
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Idle Session Timeout
# How many milliseconds of inactivity before the idle-timeout warning appears.
# Default: 900000 (15 minutes)
NEXT_PUBLIC_IDLE_TIMEOUT_MS=900000

# Idle Session Grace Period
# How many milliseconds the countdown warning is shown before auto-disconnect.
# Default: 60000 (1 minute)
NEXT_PUBLIC_IDLE_GRACE_PERIOD_MS=60000
